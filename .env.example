# Continuity API — environment template. Copy to `.env` and fill in. NEVER commit real values.

# --- App ---
ENVIRONMENT=development
# JSON array of allowed CORS origins
CORS_ALLOW_ORIGINS=["http://localhost:3000"]

# --- Postgres (local install; no pgvector required) ---
# Create the db first:  createdb continuity   (or: CREATE DATABASE continuity;)
DATABASE_URL=postgresql+psycopg://postgres:CHANGEME@localhost:5432/continuity

# --- Redis / Celery (local install) ---
REDIS_URL=redis://localhost:6379/0
# How often the auto-sync poller re-syncs every connected source (seconds).
SYNC_POLL_SECONDS=300

# --- Pinecone (index must be dimension=768, metric=cosine to match nomic-embed-text) ---
PINECONE_API_KEY=
PINECONE_HOST=
PINECONE_INDEX_NAME=kt

# --- AI providers (MVP = local Ollama) ---
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=qwen2.5:7b
LLM_NUM_CTX=8192
EMBED_MODEL=nomic-embed-text:latest
EMBED_DIM=768

# --- Hosted-model upgrade (leave blank until plan §17 trigger) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- App URLs ---
WEB_BASE_URL=http://localhost:3001

# --- Connector secrets ---
# 64 hex chars (32 bytes), e.g. `python -c "import secrets;print(secrets.token_hex(32))"`
TOKEN_ENCRYPTION_KEY=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth (Drive + Docs + Gmail). Redirect URI must match the Cloud console exactly.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/connectors/google/callback

# Atlassian OAuth (Jira + Confluence). Redirect must match the developer console exactly.
ATLASSIAN_CLIENT_ID=
ATLASSIAN_CLIENT_SECRET=
ATLASSIAN_REDIRECT_URI=http://localhost:8000/connectors/atlassian/callback

# --- Object storage (Supabase Storage / R2 / S3-compatible) ---
STORAGE_ENDPOINT=
STORAGE_REGION=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_BUCKET=

# --- Observability ---
SENTRY_DSN=
